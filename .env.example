# Environment Configuration Template
# Copy this file to .env.production and fill in the values

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application name displayed in UI
VITE_APP_NAME="Restaurant Management System"

# Application version (keep in sync with package.json)
VITE_APP_VERSION="1.0.0"

# Environment identifier
VITE_ENVIRONMENT="production"

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# Enable demo mode (WARNING: Only use in development/staging)
# Demo mode allows login with any password - NEVER enable in production
VITE_ENABLE_DEMO_MODE=false

# Session timeout in milliseconds (default: 1 hour)
VITE_SESSION_TIMEOUT=3600000

# JWT secret key (REQUIRED in production - generate a strong random string)
# Generate with: openssl rand -base64 32
# VITE_JWT_SECRET=your-super-secret-jwt-key-here

# Maximum login attempts before lockout
VITE_MAX_LOGIN_ATTEMPTS=5

# Account lockout duration in milliseconds (default: 15 minutes)
VITE_LOCKOUT_DURATION=900000

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Backend API base URL (when backend is implemented)
# Development: http://localhost:3000/api
# Production: https://api.yourrestaurant.com
# VITE_API_URL=https://api.yourrestaurant.com

# API request timeout in milliseconds
# VITE_API_TIMEOUT=30000

# API version
# VITE_API_VERSION=v1

# =============================================================================
# DATABASE CONFIGURATION (Backend only - do not expose to frontend)
# =============================================================================

# These should be set on the server/backend only, NOT in Vite env vars
# Listed here for documentation purposes

# Database connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/restaurant_db

# Database connection pool size
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable analytics dashboard
VITE_ENABLE_ANALYTICS=true

# Enable real-time notifications (requires WebSocket support)
VITE_ENABLE_NOTIFICATIONS=false

# Enable barcode scanning feature
VITE_ENABLE_BARCODE_SCANNING=false

# Enable multi-location support
VITE_ENABLE_MULTI_LOCATION=true

# Enable vendor management
VITE_ENABLE_VENDOR_MANAGEMENT=true

# Enable ML-powered forecasting
VITE_ENABLE_FORECASTING=true

# Enable audit logging
VITE_ENABLE_AUDIT_LOG=true

# Enable beta features
VITE_ENABLE_BETA_FEATURES=false

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry environment
# VITE_SENTRY_ENVIRONMENT=production

# Sentry sample rate (0.0 to 1.0)
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Enable debug logging (disable in production)
VITE_DEBUG_MODE=false

# Log level: error, warn, info, debug
VITE_LOG_LEVEL=error

# =============================================================================
# ANALYTICS
# =============================================================================

# Google Analytics tracking ID (optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Plausible Analytics domain (optional)
# VITE_PLAUSIBLE_DOMAIN=yourrestaurant.com

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Email service configuration (Backend only)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourrestaurant.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@yourrestaurant.com

# File storage configuration (Backend only)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=restaurant-uploads
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# =============================================================================
# PERFORMANCE
# =============================================================================

# Enable service worker for offline support
VITE_ENABLE_SERVICE_WORKER=false

# CDN URL for static assets (optional)
# VITE_CDN_URL=https://cdn.yourrestaurant.com

# Maximum bundle size warning (in KB)
VITE_MAX_BUNDLE_SIZE=1000

# =============================================================================
# LOCALIZATION
# =============================================================================

# Default language
VITE_DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=en

# Default timezone
VITE_DEFAULT_TIMEZONE=America/New_York

# Default currency
VITE_DEFAULT_CURRENCY=USD

# =============================================================================
# BUSINESS RULES
# =============================================================================

# Tax rate (as decimal, e.g., 0.08 for 8%)
VITE_DEFAULT_TAX_RATE=0.08

# Inventory alert thresholds
VITE_LOW_STOCK_WARNING_DAYS=7
VITE_EXPIRATION_WARNING_DAYS=7

# Order approval workflow
VITE_REQUIRE_MANAGER_APPROVAL=true
VITE_REQUIRE_ADMIN_APPROVAL=true

# Minimum order value for approval bypass (in dollars)
# VITE_AUTO_APPROVE_THRESHOLD=50

# =============================================================================
# RATE LIMITING (Backend configuration)
# =============================================================================

# These should be configured on the backend/API gateway
# Listed here for documentation purposes

# Login endpoint rate limit (requests per minute)
# RATE_LIMIT_LOGIN=10

# API endpoint rate limit per user (requests per minute)
# RATE_LIMIT_API_USER=100

# Public endpoint rate limit per IP (requests per hour)
# RATE_LIMIT_PUBLIC=1000

# =============================================================================
# SECURITY HEADERS (Web server configuration)
# =============================================================================

# These should be configured in nginx/apache/hosting platform
# Listed here for documentation purposes

# Content Security Policy
# CSP_DEFAULT_SRC='self'
# CSP_SCRIPT_SRC='self' 'unsafe-inline' 'unsafe-eval'
# CSP_STYLE_SRC='self' 'unsafe-inline'

# CORS allowed origins (Backend only)
# CORS_ALLOWED_ORIGINS=https://yourrestaurant.com,https://www.yourrestaurant.com

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Build optimization level
VITE_BUILD_MINIFY=true

# Generate source maps (disable in production for security)
VITE_BUILD_SOURCEMAP=false

# Drop console statements in production
VITE_DROP_CONSOLE=true

# Enable bundle analysis
VITE_ANALYZE_BUNDLE=false

# =============================================================================
# NOTES
# =============================================================================

# IMPORTANT SECURITY NOTES:
# 
# 1. Never commit this file with real secrets to version control
# 2. All sensitive values should use environment-specific secrets management
# 3. Rotate secrets regularly (at least quarterly)
# 4. Use strong, randomly generated values for all secrets
# 5. Prefix with VITE_ only for variables that need to be exposed to frontend
# 6. Backend-only secrets should NEVER have VITE_ prefix
# 7. Review and audit environment variables regularly
# 8. Use different values for dev, staging, and production
# 9. Enable monitoring and alerting for suspicious activities
# 10. Document any custom environment variables added

# REQUIRED VARIABLES FOR PRODUCTION:
# - VITE_API_URL (when backend is implemented)
# - VITE_JWT_SECRET (when authentication is implemented)
# - DATABASE_URL (backend only, when implemented)
# - SMTP configuration (for email notifications)

# OPTIONAL BUT RECOMMENDED:
# - VITE_SENTRY_DSN (error tracking)
# - VITE_GA_TRACKING_ID or VITE_PLAUSIBLE_DOMAIN (analytics)
# - AWS configuration (if using S3 for file storage)
